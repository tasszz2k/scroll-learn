{
  "manifest_version": 3,
  "name": "ScrollLearn",
  "version": "1.17.2",
  "description": "Learn while you scroll - quizzes injected into social feeds with spaced repetition.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "nativeMessaging",
    "sidePanel",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.youtube.com/*",
    "https://www.instagram.com/*",
    "https://gemini.google.com/*",
    "https://hexgrad-kokoro-tts.hf.space/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; frame-src https://www.youtube-nocookie.com https://www.youtube.com"
  },
  "action": {
    "default_title": "ScrollLearn",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "index.html",
  "side_panel": {
    "default_path": "src/sidebar/sidebar.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.youtube.com/*",
        "https://*.instagram.com/*"
      ],
      "js": [
        "src/content/content.ts"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/notes.ts"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/content/gemini.ts"
      ],
      "run_at": "document_idle"
    }
  ]
}
